// Telemetry and Learning Models
model TelemetryEvent {
  id          String   @id @default(cuid())
  eventType   String   // CLICK, VIEW, FEEDBACK, SEARCH, MATCH_ACCEPT, MATCH_REJECT
  userId      String?
  startupId   String?
  sessionId   String
  properties  Json     // Event-specific data
  createdAt   DateTime @default(now())
  
  @@index([eventType])
  @@index([userId])
  @@index([createdAt])
}

model FeedbackEvent {
  id          String   @id @default(cuid())
  type        String   // THUMBS_UP, THUMBS_DOWN, SCORE, CORRECTION
  targetType  String   // INVESTOR_MATCH, SCHEME_RECOMMENDATION, DOCUMENT_CLASSIFICATION
  targetId    String
  userId      String
  score       Int?     // 1-5 rating
  comment     String?
  createdAt   DateTime @default(now())
  
  @@index([targetType, targetId])
  @@index([userId])
}

model ModelPerformance {
  id          String   @id @default(cuid())
  modelName   String   // INVESTOR_MATCHER, DOCUMENT_CLASSIFIER, SCHEME_MATCHER
  version     String
  accuracy    Float
  precision   Float
  recall      Float
  f1Score     Float
  latency     Float    // Average inference time in ms
  evaluatedAt DateTime @default(now())
  
  @@index([modelName])
}

model ABTest {
  id          String   @id @default(cuid())
  name        String
  variantA    String   // Model/Config version A
  variantB    String   // Model/Config version B
  trafficSplit Int     // Percentage to variant B (0-100)
  startDate   DateTime
  endDate     DateTime?
  winner      String?
  status      String   // DRAFT, ACTIVE, COMPLETED, ROLLED_BACK
  createdAt   DateTime @default(now())
}

model ABTestResult {
  id          String   @id @default(cuid())
  testId      String
  variant     String   // A or B
  metricName  String   // CLICK_THROUGH_RATE, MATCH_ACCEPT_RATE, etc.
  metricValue Float
  sampleSize  Int
  recordedAt  DateTime @default(now())
  
  @@index([testId, variant])
}

model UserActionSummary {
  id          String   @id @default(cuid())
  userId      String
  actionType  String   // SEARCH, CLICK, UPLOAD, SHARE, EXPORT
  count       Int      @default(1)
  lastSeen    DateTime @default(now())
  
  @@unique([userId, actionType])
}